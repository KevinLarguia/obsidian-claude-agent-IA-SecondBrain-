    { "id": "n01", "type": "text", "x": -1060, "y": -510, "width": 240, "height": 65, "text": "💬 **Mensaje del usuario**", "color": "1" },
    { "id": "n02", "type": "text", "x": -1060, "y": -430, "width": 240, "height": 65, "text": "📅 **Nota diaria activa**", "color": "1" },
    { "id": "n03", "type": "text", "x": -1060, "y": -350, "width": 240, "height": 65, "text": "📥 **Inbox item**", "color": "1" },
    { "id": "n04", "type": "text", "x": -1060, "y": -270, "width": 240, "height": 65, "text": "📁 **Proyecto activo**", "color": "1" },
    { "id": "n05", "type": "text", "x": -1060, "y": -190, "width": 240, "height": 65, "text": "🌐 **URL externa**", "color": "1" },
    { "id": "n06", "type": "text", "x": -1060, "y": -110, "width": 240, "height": 65, "text": "🎯 **Contexto previo**", "color": "1" },
    { "id": "n07", "type": "text", "x": -1060, "y": -30,  "width": 240, "height": 65, "text": "👤 **Perfil del usuario**", "color": "1" },

    { "id": "n08", "type": "text", "x": -620, "y": -510, "width": 240, "height": 85, "text": "**CLAUDE.md**\nSystem prompt estructurado", "color": "2" },
    { "id": "n09", "type": "text", "x": -620, "y": -405, "width": 240, "height": 85, "text": "**MEMORY.md**\nÍndice de memorias activo", "color": "2" },
    { "id": "n10", "type": "text", "x": -620, "y": -300, "width": 240, "height": 85, "text": "**user_*.md**\nPerfil y preferencias", "color": "2" },
    { "id": "n11", "type": "text", "x": -620, "y": -195, "width": 240, "height": 85, "text": "**project_*.md**\nEstado de proyectos", "color": "2" },
    { "id": "n12", "type": "text", "x": -620, "y": -90,  "width": 240, "height": 85, "text": "**feedback_*.md**\nPatrones aprendidos", "color": "2" },
    { "id": "n13", "type": "text", "x": -620, "y":  15,  "width": 240, "height": 85, "text": "**settings.json**\nPermisos del agente", "color": "2" },

    { "id": "n14", "type": "text", "x": -180, "y": -510, "width": 240, "height": 90, "text": "**obsidian-markdown**\nSintaxis OFM, callouts, frontmatter", "color": "3" },
    { "id": "n15", "type": "text", "x": -180, "y": -400, "width": 240, "height": 90, "text": "**obsidian-cli**\nInteracción directa con vault", "color": "3" },
    { "id": "n16", "type": "text", "x": -180, "y": -290, "width": 240, "height": 90, "text": "**obsidian-bases**\nVistas .base con filtros", "color": "3" },
    { "id": "n17", "type": "text", "x": -180, "y": -180, "width": 240, "height": 90, "text": "**json-canvas**\nMapas visuales .canvas", "color": "3" },
    { "id": "n18", "type": "text", "x": -180, "y": -70,  "width": 240, "height": 90, "text": "**defuddle**\nExtracción limpia de web", "color": "3" },

    { "id": "n19", "type": "text", "x": 260, "y": -510, "width": 240, "height": 105, "text": "**Context Integrator**\nFusiona CLAUDE.md + memoria + vault en contexto único", "color": "4" },
    { "id": "n20", "type": "text", "x": 260, "y": -385, "width": 240, "height": 105, "text": "**Pattern Recognizer**\nDetecta personas, proyectos y triggers en el input", "color": "4" },
    { "id": "n21", "type": "text", "x": 260, "y": -260, "width": 240, "height": 105, "text": "**Priority Evaluator**\nPrioriza acción según reglas del CLAUDE.md", "color": "4" },
    { "id": "n22", "type": "text", "x": 260, "y": -135, "width": 240, "height": 105, "text": "**Knowledge Connector**\nGenera enlaces semánticos entre notas del vault", "color": "4" },
    { "id": "n23", "type": "text", "x": 260, "y": -10,  "width": 240, "height": 105, "text": "**Memory Writer**\nActualiza memory/ con nuevas inferencias", "color": "4" },

    { "id": "n24", "type": "text", "x": 700, "y": -510, "width": 240, "height": 85, "text": "📝 **Crear / editar nota**\nen vault estructurado", "color": "5" },
    { "id": "n25", "type": "text", "x": 700, "y": -405, "width": 240, "height": 85, "text": "🔗 **Generar wikilinks**\nconexiones entre notas", "color": "5" },
    { "id": "n26", "type": "text", "x": 700, "y": -300, "width": 240, "height": 85, "text": "📥 **Capturar a inbox/**\nsin fricción, automático", "color": "5" },
    { "id": "n27", "type": "text", "x": 700, "y": -195, "width": 240, "height": 85, "text": "🧠 **Actualizar memory/**\npersistencia entre sesiones", "color": "5" },
    { "id": "n28", "type": "text", "x": 700, "y": -90,  "width": 240, "height": 85, "text": "📊 **Crear canvas / base**\nvisualizaciones del vault", "color": "5" },
    { "id": "n29", "type": "text", "x": 700, "y":  15,  "width": 240, "height": 85, "text": "✅ **Respuesta al usuario**\ncon contexto completo", "color": "5" },

    { "id": "n30", "type": "text", "x": -195, "y": 235, "width": 160, "height": 60, "text": "📅 daily-notes/" },
